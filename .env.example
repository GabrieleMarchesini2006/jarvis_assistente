# Copia questo file in ".env" e compila i valori.

# Token del bot ottenuto da @BotFather su Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Il TUO id utente Telegram (numerico). Scrivi a @userinfobot per scoprirlo.
# Il bot risponderà solo a te.
ALLOWED_USER_ID=123456789

# Stringa segreta casuale (lettere e numeri) per proteggere il webhook.
WEBHOOK_SECRET=scrivi-una-stringa-casuale-lunga

# Chiave API Gemini, GRATIS da Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...
# Modello (opzionale, default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Token dell'integrazione Notion (https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_...
# Id della pagina Notion sotto cui creare le nuove note
# (dall'URL della pagina: notion.so/Titolo-<QUESTO-ID>)
NOTION_PARENT_PAGE_ID=

# Fuso orario per il calendario
TIMEZONE=Europe/Rome
